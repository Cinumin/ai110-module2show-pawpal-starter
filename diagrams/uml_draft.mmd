classDiagram
    class User {
        +str name
        +float time_available
        +str min_priority
        +add_task(pet, task) void
        +edit_task(pet, title, ...) void
        +remove_task(pet, title) void
    }

    class Pet {
        +str name
        +str species
        +float age
        +list~Task~ tasks
    }

    class Task {
        +str title
        +float duration
        +str priority
    }

    class Schedule {
        +list~Task~ scheduled_tasks
        +generate(tasks, user) void
        +display() void
        +display_reasoning() void
    }

    User "1" --> "1..*" Pet : owns
    Pet "1" --> "*" Task : has
    Schedule --> Pet : reads tasks from
    Schedule --> User : applies constraints from
